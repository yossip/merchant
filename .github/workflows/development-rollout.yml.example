name: Development Rollout

on:
  push:
    branches: [ "development" ]
  pull_request:
    branches: [ "development" ]

# Example workflow purely for demonstration purposes
# Does not trigger real deployments unless renamed and configured
jobs:
  build_and_deploy_dev:
    runs-on: ubuntu-latest
    environment: development

    steps:
    - name: Checkout Code
      uses: actions/checkout@v4

    - name: Lint and Unit Tests
      run: |
        echo "Running linters..."
        
        echo "Running Helm linter..."
        helm lint ./charts/devops-base-chart
        helm lint ./merchant-core-api-chart
        
        echo "Running Terraform formatting check..."
        terraform fmt -check -recursive infra/terraform
        
        echo "Running fast unit tests..."

    - name: Build and Push Base Docker Image
      run: |
        echo "Building DevOps-managed base image..."
        echo "docker build -t merchant-base:latest -f docker/Dockerfile.base ."
        echo "Pushing to ECR: merchant-base:latest"

    - name: Build and Push Application Docker Image
      run: |
        echo "Building merchant-core-api image (inherits from merchant-base)..."
        echo "docker build -t merchant-core-api:${{ github.sha }} -f Dockerfile ."
        echo "Pushing to ECR: merchant-core-api:${{ github.sha }}"

    - name: Terraform Plan
      run: |
        echo "Running Terraform Plan for development environment..."
        echo "terraform -chdir=infra/terraform/01-core-eks init"
        echo "terraform -chdir=infra/terraform/01-core-eks plan -var-file=../../environments/development/01-core-eks.tfvars -out=tfplan"
        echo "terraform -chdir=infra/terraform/01-core-eks show -json tfplan > tfplan.json"

    - name: Check for Resource Deletions
      run: |
        echo "Analyzing terraform plan for any destructive actions..."
        # Example logic using jq to parse the plan JSON:
        # DELETIONS=$(jq '[.resource_changes[] | select(.change.actions | contains(["delete"]))] | length' tfplan.json)
        # if [ "$DELETIONS" -gt 0 ]; then
        #   echo "WARNING: Plan contains resources intended for deletion."
        #   echo "Manual approval is required."
        #   exit 1 # Failing the step halts the pipeline until manual intervention
        # fi
        echo "No destructive actions detected. Proceeding..."

    - name: Apply Base Infrastructure (Terraform)
      run: |
        echo "Applying the approved Terraform Plan..."
        echo "terraform -chdir=infra/terraform/01-core-eks apply tfplan"

    - name: Deploy to Development EKS
      run: |
        echo "Updating kubeconfig for development cluster..."
        echo "Building Helm chart dependencies..."
        echo "helm dependency update ./merchant-core-api-chart"
        echo "Applying application via Helm..."
        echo "helm upgrade --install merchant-core-api ./merchant-core-api-chart -f ./merchant-core-api-chart/environments/development.yaml --namespace development --create-namespace"

    - name: Run Basic Health Checks
      run: |
        echo "Checking application health endpoints..."

    # ---- DORA Metrics ----
    - name: Calculate Lead Time
      id: lead_time
      run: |
        # Lead time = seconds since first commit on branch until now
        echo "FIRST_COMMIT_TS=$(git log --reverse --format=%ct | head -1)" >> $GITHUB_ENV
        echo "DEPLOY_TS=$(date +%s)" >> $GITHUB_ENV

    - name: Emit DORA Metrics (Datadog + Coralogix)
      if: always()
      env:
        DD_API_KEY: ${{ secrets.DD_API_KEY }}
        DORA_ENVIRONMENT: development
        DORA_EVENT_TYPE: ${{ job.status == 'success' && 'deploy_succeeded' || 'deploy_failed' }}
        DORA_COMMIT_SHA: ${{ github.sha }}
        DORA_PIPELINE_URL: ${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}
        DORA_LEAD_TIME_SECONDS: ${{ env.DEPLOY_TS && env.FIRST_COMMIT_TS && format('{0}', fromJSON(env.DEPLOY_TS) - fromJSON(env.FIRST_COMMIT_TS)) || '0' }}
        DORA_ERROR_COUNT: ${{ job.status == 'failure' && '1' || '0' }}
        DORA_SECURITY_REJECTS: "0"
      run: |
        echo "bash scripts/emit-dora-metrics.sh"
